# Discord Configuration — Outbound webhooks (one per channel)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
# Optional: per-channel webhooks (falls back to DISCORD_WEBHOOK_URL if not set)
# DISCORD_WEBHOOK_HERE_GONE=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_CLOCK_LOGS=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_ADMIN=https://discord.com/api/webhooks/...

# Discord Bot — for reading the #Schedules channel (inbound)
# Create a bot at https://discord.com/developers/applications, add it to your
# server with "Read Message History" permission on the Schedules channel,
# then paste the bot token and the channel ID below.
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_SCHEDULES_CHANNEL_ID=123456789012345678

# Camera Configuration
CAMERA_INDEX=0
# Multi-camera: comma-separated indices
# CAMERA_INDICES=0,1

# Optional: Override default paths
# EMBEDDINGS_PATH=data/employees/embeddings.pkl
# LOGS_DIR=data/logs

# Work-hours fallback (used only when no schedule is posted in Discord)
# EXPECTED_START_HOUR=9
# EXPECTED_START_MINUTE=0
# EXPECTED_END_HOUR=17
